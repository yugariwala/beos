# Google Maps API Key (Required for map features)
# Get your key from: https://console.cloud.google.com/google/maps-apis/
# Enable these APIs: Maps JavaScript API, Places API, Visualization API
# Restrict by domain: localhost:5173, your-app.vercel.app
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Backend API URL (if different from default)
# VITE_API_URL=http://localhost:5000/api
